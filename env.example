# Variáveis de ambiente da AIFLUENT LP.
# Copie para `.env.local` e preencha. NUNCA commite valores reais.
# Em produção, configure estas variáveis no painel da Vercel (Project → Settings → Environment Variables).

# Caixa de entrada que recebe os contatos do formulário
CONTACT_INBOX=contato@aifluent.com.br

# Remetente dos e-mails (precisa ser um domínio verificado no Resend)
CONTACT_FROM="AIFLUENT <contato@aifluent.com.br>"

# Chave da API do Resend — usada em src/app/api/contato/route.ts
# Sem ela, o formulário valida e responde ok, porém não envia e-mail (delivered:false).
RESEND_API_KEY=
